---
layout: feed
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

	<title>Hank Quinlan's Blog</title>
	<link href="https://jellybeanjunction.co.uk/blog/atom.xml" rel="self"/>
	<link href="https://jellybeanjunction.co.uk/blog"/>
	<updated>{{ site.time | date_to_xmlschema }}</updated>
	<id>https://jellybeanjunction.co.uk/blog</id>
	<author>
		<name>Kate Rowell</name>
		<email>info@jellybeanjunction.co.uk</email>
	</author>

	{% for post in site.posts %}
		<entry>
			<title>{{ post.title }}</title>
			<link href="https://jellybeanjunction.co.uk{{ post.url }}"/>
			<updated>{{ post.date | date_to_xmlschema }}</updated>
			<id>https://jellybeanjunction.co.uk/blog{{ post.id }}</id>
			<content type="html">{{ post.content | xml_escape }}</content>
		</entry>
	{% endfor %}

</feed>
